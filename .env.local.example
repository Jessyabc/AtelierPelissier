# AI Assistant — required for the chat widget to work
OPENAI_API_KEY=sk-your-key-here

# Cutlist PDF OCR — when PDFs have no selectable text (scanned/image), LlamaParse is used. Same key as Llama Cloud.
# LLAMAPARSE_API_KEY=llx-your-key-here

# Supabase Auth (managed login). App data stays in Neon via DATABASE_URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: absolute URL for invite links (e.g. https://woodops.ca). Falls back to VERCEL_URL on Vercel.
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Optional: comma-separated emails for service-call notification mailto drafts (team)
# SERVICE_CALL_NOTIFY_EMAILS=ops@example.com,shop@example.com

# Neon / Postgres (Prisma)
# DATABASE_URL=postgresql://...
