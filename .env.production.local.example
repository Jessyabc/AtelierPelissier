# Same Postgres as Vercel Production DATABASE_URL (e.g. Neon). Copy this file to .env.production.local.
# After you change prisma/schema.prisma, sync the live DB: npm run sync:website
# (never commit .env.production.local)

DATABASE_URL=postgresql://user:pass@ep-example.region.aws.neon.tech/neondb?sslmode=require
